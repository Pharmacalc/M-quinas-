const COR={weld:0xffffff, ball:0xb49cff, hinge:0x6fd6c8, pino:0xf0a860,
           trilho:0x62b0f0, motor:0x7ee06a};
function eixoMundo(i){ return new THREE.Vector3(i===0?1:0,i===1?1:0,i===2?1:0); }
function dirDeAng(az,el){
  const a=az*Math.PI/180, e=el*Math.PI/180;
  return new THREE.Vector3(Math.cos(e)*Math.cos(a), Math.sin(e), Math.cos(e)*Math.sin(a)).normalize();
}
function angDeDir(d){
  const v=d.clone().normalize();
  return {az:Math.atan2(v.z,v.x)*180/Math.PI, el:Math.asin(Math.max(-1,Math.min(1,v.y)))*180/Math.PI};
}
// eixo próprio de uma peça (X local) em coordenadas do mundo
function eixoDaPeca(p){
  const q=p.body.quaternion, v=q.vmult(new CANNON.Vec3(1,0,0));
  return new THREE.Vector3(v.x,v.y,v.z).normalize();
}
let novoAz=90, novoEl=0;   // padrão = eixo Z
function mkMarcador(kind, transp){
  const g=new THREE.Group();
  const op = transp?{transparent:true,opacity:0.55}:{};
  if(kind==='ball'||kind==='weld'){
    const m=new THREE.Mesh(new THREE.SphereGeometry(kind==='ball'?0.022:0.014,16,12),
      new THREE.MeshBasicMaterial(Object.assign({color:COR[kind]},op)));
    g.add(m); g.userData.bola=m;
  }
  if(kind==='hinge'||kind==='pino'||kind==='trilho'){
    // LINHA = eixo da dobradiça: mostra orientação E local
    const geo=new THREE.CylinderGeometry(0.005,0.005,0.34,10);
    const m=new THREE.Mesh(geo,new THREE.MeshBasicMaterial(Object.assign({color:COR[kind]},op)));
    g.add(m); g.userData.haste=m;
    const p=new THREE.Mesh(new THREE.SphereGeometry(0.016,14,10),
      new THREE.MeshBasicMaterial(Object.assign({color:COR[kind]},op)));
    g.add(p);
  }
  return g;
}
function porMarcador(g, kind, pos, axis){
  g.position.copy(pos);
  if((kind==='hinge'||kind==='pino'||kind==='trilho')&&g.userData.haste){
    g.quaternion.setFromUnitVectors(new THREE.Vector3(0,1,0), axis.clone().normalize());
  }
}

// os "lugares adequados": geometria notável de cada peça
function pontosLocais(p){
  const q=p.par, L=[];
  const add=(x,y,z,nome)=>L.push({v:new THREE.Vector3(x,y,z),n:nome});
  add(0,0,0,'centro');
  if(p.tipo==='barra'){
    add(q.comp/2,0,0,'ponta'); add(-q.comp/2,0,0,'ponta');
    add(q.comp/4,0,0,'1/4'); add(-q.comp/4,0,0,'1/4');
  } else if(p.tipo==='placa'){
    [-1,1].forEach(sx=>[-1,1].forEach(sz=>add(sx*q.larg/2,0,sz*q.prof/2,'canto')));
    add(q.larg/2,0,0,'meio aresta'); add(-q.larg/2,0,0,'meio aresta');
    add(0,0,q.prof/2,'meio aresta'); add(0,0,-q.prof/2,'meio aresta');
    add(0,q.esp/2,0,'face'); add(0,-q.esp/2,0,'face');
  } else if(p.tipo==='roda'){
    add(q.larg/2,0,0,'eixo'); add(-q.larg/2,0,0,'eixo');
    add(0,q.raio,0,'aro'); add(0,-q.raio,0,'aro');
  } else if(p.tipo==='arco'){
    const tot=q.arco*Math.PI/180;
    [-1,1].forEach(s=>add(q.raio*Math.sin(s*tot/2),0,q.raio*Math.cos(s*tot/2)-q.raio,'ponta'));
    add(0,0,-q.raio,'centro do arco');
  }
  return L;
}
function pontosMundo(lista){
  const out=[];
  lista.forEach(function(p){
    pontosLocais(p).forEach(function(o){
      const v=new CANNON.Vec3(o.v.x,o.v.y,o.v.z);
      const w=p.body.pointToWorldFrame(v);
      out.push({p:new THREE.Vector3(w.x,w.y,w.z), n:o.n, peca:p});
    });
  });
  return out;
}
let imanOn=true, imaAtivo=null, imaRaio=46;   // px na tela: consistente em qualquer zoom
function paraTela(v){
  const p=v.clone().project(cam);
  const r=rend.domElement;
  return new THREE.Vector2((p.x*0.5+0.5)*r.clientWidth, (-p.y*0.5+0.5)*r.clientHeight);
}
// ímã SUAVE: atrai se estiver perto NA TELA, senão deixa você em paz
function comIma(v,lista){
  imaAtivo=null;
  if(!imanOn) return v;
  const vt=paraTela(v);
  let melhor=null, dmin=imaRaio;
  pontosMundo(lista).forEach(function(c){
    const d=vt.distanceTo(paraTela(c.p));
    if(d<dmin){ dmin=d; melhor=c; }
  });
  if(melhor){ imaAtivo=melhor; return melhor.p.clone(); }
  return v;
}
let prev=null, pivotUser=null, pivotLivre=null;
function pivotAtual(){
  if(pivotUser) return pivotUser.clone();
  const a=sel[0].body.position, b=sel[1].body.position;
  return new THREE.Vector3((a.x+b.x)/2,(a.y+b.y)/2,(a.z+b.z)/2);
}
// põe o pivô na superfície de contato entre as duas peças
function noContato(){
  if(sel.length!==2) return;
  const A=sel[0], B=sel[1];
  const pa=new THREE.Vector3(A.body.position.x,A.body.position.y,A.body.position.z);
  const pb=new THREE.Vector3(B.body.position.x,B.body.position.y,B.body.position.z);
  const dir=new THREE.Vector3().subVectors(pb,pa).normalize();
  const h1=new THREE.Raycaster(pa,dir).intersectObject(B.mesh,true);
  const h2=new THREE.Raycaster(pb,dir.clone().negate()).intersectObject(A.mesh,true);
  let p=null;
  if(h1.length&&h2.length) p=h1[0].point.clone().add(h2[0].point).multiplyScalar(0.5);
  else if(h1.length) p=h1[0].point.clone();
  else if(h2.length) p=h2[0].point.clone();
  if(p){ pivotUser=p; verPrevia(); }
}
function verPrevia(){
  if(prev){ scene.remove(prev); prev=null; }
  if(sel.length!==2) return;
  const a=sel[0].body.position, b=sel[1].body.position;
  const mid=pivotAtual();
  prev=new THREE.Group();
  const bola=mkMarcador('ball',true); bola.position.copy(mid); prev.add(bola);
  prev.userData.bola=bola;
  const eixo=mkMarcador('hinge',true); porMarcador(eixo,'hinge',mid,dirDeAng(novoAz,novoEl)); prev.add(eixo);
  // pontos notáveis: onde a junta tende a fazer sentido
  if(imanOn) pontosMundo(sel).forEach(function(c){
    const on = imaAtivo && c.p.distanceTo(imaAtivo.p)<1e-9;
    const d=new THREE.Mesh(new THREE.SphereGeometry(on?0.014:0.007,10,8),
      new THREE.MeshBasicMaterial({color:on?0x7ee06a:0x66707e,
        transparent:true,opacity:on?1:0.5}));
    d.position.copy(c.p); prev.add(d);
  });
  // linhas do pivô até CADA peça: mostra a relação com as duas
  [[a,0x4a90d9],[b,0xd9a04a]].forEach(function(par){
    const l=new THREE.Line(new THREE.BufferGeometry().setFromPoints(
      [mid.clone(), new THREE.Vector3(par[0].x,par[0].y,par[0].z)]),
      new THREE.LineDashedMaterial({color:par[1],dashSize:0.015,gapSize:0.012}));
    l.computeLineDistances(); prev.add(l);
  });
  scene.add(prev);
}

let asmSeq=0;
function aplicarGrupo(p){
  if(p.asm===null){ p.body.collisionFilterGroup=2; p.body.collisionFilterMask=-1; return; }
  const G=1<<((p.asm%28)+2);
  p.body.collisionFilterGroup=G; p.body.collisionFilterMask=-1 & ~G;
}
function unir(a,b){
  let k;
  if(a.asm===null && b.asm===null) k=asmSeq++;
  else if(a.asm===null) k=b.asm;
  else if(b.asm===null) k=a.asm;
  else k=Math.min(a.asm,b.asm);
  const velho=(a.asm!==null&&b.asm!==null)?Math.max(a.asm,b.asm):null;
  parts.forEach(function(p){ if(velho!==null&&p.asm===velho) p.asm=k; });
  a.asm=k; b.asm=k;
  parts.forEach(aplicarGrupo);
}

const ray=new THREE.Raycaster(), ptr=new THREE.Vector2();
let selLink=null;
function pickLink(cx,cy){
  const r=rend.domElement.getBoundingClientRect();
  ptr.x=((cx-r.left)/r.width)*2-1; ptr.y=-((cy-r.top)/r.height)*2+1;
  ray.setFromCamera(ptr,cam);
  for(let i=0;i<links.length;i++)
    if(links[i].mk && ray.intersectObject(links[i].mk,true).length) return links[i];
  return null;
}
function pick(cx,cy){
  const r=rend.domElement.getBoundingClientRect();
  ptr.x=((cx-r.left)/r.width)*2-1; ptr.y=-((cy-r.top)/r.height)*2+1;
  ray.setFromCamera(ptr,cam);
  for(let i=0;i<parts.length;i++) if(ray.intersectObject(parts[i].mesh,true).length) return parts[i];
  return null;
}
function toggle(p){
  if(sel.indexOf(p)>=0) sel=sel.filter(x=>x!==p);
  else { sel.push(p); if(sel.length>2) sel.shift(); }
  pivotUser=null; pivotLivre=null; modoPivo=false;   // par novo, pivô volta ao automático
  paint(); ui();
}
function paint(){
  links.forEach(function(l){ if(!l.mk) return;
    const cor=(l.motor&&l.motor.on)?COR.motor:COR[l.kind];
    l.mk.traverse(function(o){ if(o.material&&o.material.color) o.material.color.setHex(cor); });
    l.mk.scale.setScalar(l===selLink?1.35:1); });
  parts.forEach(p=>{ const i=sel.indexOf(p);
    p.mesh.traverse(o=>{ if(o.material) o.material.emissive=new THREE.Color(i===0?0x2b4a70:i===1?0x6a4a20:0x000000); }); });
}
// peças ligadas formam UM bloco: percorre o grafo de ligações
function grupoDe(p){
  const vis=[p], fila=[p];
  while(fila.length){
    const cur=fila.pop();
    links.forEach(function(l){
      const o = (l.pa===cur)?l.pb : (l.pb===cur)?l.pa : null;
      if(o && vis.indexOf(o)<0){ vis.push(o); fila.push(o); }
    });
  }
  return vis;
}
// move o bloco inteiro, com as juntas junto
function moverGrupo(g,dx,dy,dz){
  g.forEach(function(o){
    o.body.position.x+=dx; o.body.position.y+=dy; o.body.position.z+=dz;
    o.body.velocity.set(0,0,0); o.body.angularVelocity.set(0,0,0);
    o.home=o.body.position.clone();
  });
  links.forEach(function(l){
    if(g.indexOf(l.pa)>=0 && g.indexOf(l.pb)>=0) l.pivW.add(new THREE.Vector3(dx,dy,dz));
  });
}
// gira o bloco em torno do centro da peça editada
function girarGrupo(p,qNovo){
  const g=grupoDe(p);
  const dq=qNovo.mult(p.body.quaternion.inverse());
  const c=p.body.position.clone();
  g.forEach(function(o){
    if(o===p) return;
    const r=o.body.position.vsub(c);
    const r2=dq.vmult(r);
    o.body.position.copy(c.vadd(r2));
    o.body.quaternion.copy(dq.mult(o.body.quaternion));
    const e=new CANNON.Vec3(); o.body.quaternion.toEuler(e);
    o.rot.x=e.x*180/Math.PI; o.rot.y=e.y*180/Math.PI; o.rot.z=e.z*180/Math.PI;
    o.body.velocity.set(0,0,0); o.body.angularVelocity.set(0,0,0);
    o.home=o.body.position.clone(); o.hq=o.body.quaternion.clone();
  });
  p.body.quaternion.copy(qNovo);
  links.forEach(function(l){
    if(g.indexOf(l.pa)<0 || g.indexOf(l.pb)<0) return;
    const rv=new CANNON.Vec3(l.pivW.x-c.x, l.pivW.y-c.y, l.pivW.z-c.z);
    const r2=dq.vmult(rv);
    l.pivW.set(c.x+r2.x, c.y+r2.y, c.z+r2.z);
    l.axAz+=0; // eixo é recomputado a partir do corpo em refazer
  });
  g.forEach(function(o){ if(o!==p) return; o.hq=o.body.quaternion.clone(); });
}
function sync(){
  parts.forEach(p=>{ p.mesh.position.copy(p.body.position); p.mesh.quaternion.copy(p.body.quaternion); });
  links.forEach(function(l){ if(!l.mk) return;
    const w=l.pa.body.pointToWorldFrame(l.pivA);
    const pos=new THREE.Vector3(w.x,w.y,w.z);
    let ax=null;
    if((l.kind==='hinge'||l.kind==='pino'||l.kind==='trilho')&&l.axL){ const a=l.pa.body.quaternion.vmult(l.axL);
      ax=new THREE.Vector3(a.x,a.y,a.z); }
    porMarcador(l.mk,l.kind,pos,ax||new THREE.Vector3(0,1,0));
    if(l.mkB){ const wb=l.pb.body.pointToWorldFrame(l.pivB);
      l.mkB.position.set(wb.x,wb.y,wb.z); } });
}

let modoPivo=false;
function pontoNaSuperficieDe(lista,cx,cy){
