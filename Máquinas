<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cannon.js/0.6.2/cannon.min.js"></script>
<script>
function shout(m){ var e=document.getElementById('err'); e.style.display='block'; e.textContent+=m+'\n'; }
window.addEventListener('error',function(ev){ shout('ERRO: '+ev.message+' @'+ev.lineno); });
try{
if(typeof THREE==='undefined'){ shout('THREE nao carregou'); throw new Error('sem THREE'); }
if(typeof CANNON==='undefined'){ shout('CANNON nao carregou'); throw new Error('sem CANNON'); }

const stage=document.getElementById('stage');
const scene=new THREE.Scene(); scene.background=new THREE.Color(0x1b1c21);
const cam=new THREE.PerspectiveCamera(50,1,0.01,100);
const rend=new THREE.WebGLRenderer({antialias:true});
rend.domElement.style.display='block';
stage.insertBefore(rend.domElement, stage.firstChild);
scene.add(new THREE.HemisphereLight(0xbfd4ff,0x30302c,0.9));
const dl=new THREE.DirectionalLight(0xffffff,0.7); dl.position.set(3,6,3); scene.add(dl);
scene.add(new THREE.GridHelper(4,20,0x3a3b44,0x2a2b33));

const world=new CANNON.World();
world.gravity.set(0,-9.82,0); world.solver.iterations=200;  // firmeza em cadeias de solda
world.defaultContactMaterial.friction=0.6;
const ground=new CANNON.Body({mass:0,shape:new CANNON.Plane()});
ground.quaternion.setFromAxisAngle(new CANNON.Vec3(1,0,0),-Math.PI/2);
ground.collisionFilterGroup=1; ground.collisionFilterMask=-1;
world.addBody(ground);

let orb={az:0.7,el:0.45,d:2.2,t:new THREE.Vector3(0,0.3,0)};
function placeCam(){
  cam.position.set(orb.t.x+orb.d*Math.cos(orb.el)*Math.sin(orb.az),
                   orb.t.y+orb.d*Math.sin(orb.el),
                   orb.t.z+orb.d*Math.cos(orb.el)*Math.cos(orb.az));
  cam.lookAt(orb.t);
}
function pan(dx,dy){
  const s=orb.d*0.0018;
  const fwd=new THREE.Vector3(); cam.getWorldDirection(fwd);
  const right=new THREE.Vector3().crossVectors(fwd,new THREE.Vector3(0,1,0)).normalize();
  const up=new THREE.Vector3().crossVectors(right,fwd).normalize();
  orb.t.addScaledVector(right,-dx*s);
  orb.t.addScaledVector(up,dy*s);
  placeCam();
}
function verTudo(){
  if(!parts.length){ orb.t.set(0,0.3,0); orb.d=2.2; placeCam(); return; }
  const b=new THREE.Box3();
  parts.forEach(function(p){ b.expandByObject(p.mesh); });
  const c=b.getCenter(new THREE.Vector3()), sz=b.getSize(new THREE.Vector3());
  orb.t.copy(c);
  orb.d=Math.max(0.5,Math.max(sz.x,sz.y,sz.z)*2.0+0.4);
  placeCam();
}
function centrar(p){ if(!p) return;
  orb.t.set(p.body.position.x,p.body.position.y,p.body.position.z); placeCam(); }
let seguindo=null;
// centra a 2ª peça sobre a 1ª nos eixos escolhidos (não sobrepõe: alinha)
function centrarEm(quais){
  if(sel.length!==2) return;
  const alvoP=sel[0].body.position, movel=sel[1];
  const g=grupoDe(movel);
  const dx=quais.indexOf('x')>=0 ? alvoP.x-movel.body.position.x : 0;
  const dy=quais.indexOf('y')>=0 ? alvoP.y-movel.body.position.y : 0;
  const dz=quais.indexOf('z')>=0 ? alvoP.z-movel.body.position.z : 0;
  moverGrupo(g,dx,dy,dz); sync();
}
// empurra a peça/bloco selecionado por um passo fixo
function nudge(dx,dy,dz){
  const p=sel[0]; if(!p) return;
  const g=grupoDe(p);
  const menor=Math.min.apply(null,g.map(o=>o.body.position.y));
  if(menor+dy<0.02) dy=0.02-menor;
  moverGrupo(g,dx,dy,dz); sync();
}
function alvoSeguir(){
  const p = sel[0] || (selLink && selLink.pa) || parts[0];
  if(!p) return;
  if(seguindo===p){ seguindo=null; }
  else { seguindo=p; centrar(p); }
  const b=document.getElementById('btSeguir');
  if(b) b.style.background=seguindo?'#22301f':'';
}

function resize(){ const w=stage.clientWidth,h=stage.clientHeight; if(!w||!h) return;
  rend.setSize(w,h); rend.setPixelRatio(Math.min(devicePixelRatio,2));
  cam.aspect=w/h; cam.updateProjectionMatrix(); placeCam(); }
new ResizeObserver(resize).observe(stage);

const MAT={barra:0xd8a13a,arco:0xc9752f,placa:0x7f8aa0,roda:0x2e2f36};
const CAT={
  barra:{nome:'Barra reta',p:{comp:{r:[0.1,1.2],v:0.5,u:'m'},esp:{r:[0.01,0.06],v:0.025,u:'m'}}},
  arco:{nome:'Semicirculo',p:{raio:{r:[0.08,0.6],v:0.25,u:'m'},arco:{r:[20,360],v:180,u:'\u00b0'},esp:{r:[0.01,0.05],v:0.02,u:'m'}}},
  placa:{nome:'Placa',p:{larg:{r:[0.05,0.9],v:0.35,u:'m'},prof:{r:[0.05,0.9],v:0.22,u:'m'},esp:{r:[0.004,0.05],v:0.012,u:'m'}}},
  roda:{nome:'Roda',p:{raio:{r:[0.03,0.25],v:0.09,u:'m'},larg:{r:[0.01,0.1],v:0.035,u:'m'}}}
};
let parts=[],sel=[],running=false,nId=0,hingeAx=0,links=[];

function build(tipo,par){
  const g=new THREE.Group(), shapes=[];
  const mat=new THREE.MeshLambertMaterial({color:MAT[tipo]});
  if(tipo==='barra'){
    const e=par.esp;
    shapes.push({s:new CANNON.Box(new CANNON.Vec3(par.comp/2,e/2,e/2)),o:new CANNON.Vec3()});
    g.add(new THREE.Mesh(new THREE.BoxGeometry(par.comp,e,e),mat));
  } else if(tipo==='placa'){
    shapes.push({s:new CANNON.Box(new CANNON.Vec3(par.larg/2,par.esp/2,par.prof/2)),o:new CANNON.Vec3()});
    g.add(new THREE.Mesh(new THREE.BoxGeometry(par.larg,par.esp,par.prof),mat));
  } else if(tipo==='arco'){
    const n=Math.max(4,Math.round(par.arco/15)), tot=par.arco*Math.PI/180;
    const seg=2*par.raio*Math.sin(tot/(2*n)), e=par.esp;
    for(let i=0;i<n;i++){
      const a=-tot/2+tot*(i+0.5)/n;
      const px=par.raio*Math.sin(a), pz=par.raio*Math.cos(a)-par.raio;
      const q=new CANNON.Quaternion(); q.setFromAxisAngle(new CANNON.Vec3(0,1,0),a);
      shapes.push({s:new CANNON.Box(new CANNON.Vec3(seg/2*1.03,e/2,e/2)),o:new CANNON.Vec3(px,0,pz),q:q});
      const m=new THREE.Mesh(new THREE.BoxGeometry(seg*1.03,e,e),mat);
      m.position.set(px,0,pz); m.rotation.y=a; g.add(m);
    }
  } else if(tipo==='roda'){
    // colisão ESFÉRICA (cilindro do cannon afunda 80mm; esfera 0mm — medido)
    shapes.push({s:new CANNON.Sphere(par.raio),o:new CANNON.Vec3()});
    const m=new THREE.Mesh(new THREE.CylinderGeometry(par.raio,par.raio,par.larg,20),mat);
    m.rotation.z=Math.PI/2; g.add(m);
    const h=new THREE.Mesh(new THREE.CylinderGeometry(par.raio*0.42,par.raio*0.42,par.larg*1.05,14),
      new THREE.MeshLambertMaterial({color:0x9aa3b2}));
    h.rotation.z=Math.PI/2; g.add(h);
  }
  return {shapes,mesh:g};
}
function aplicar(p,shapes){
  p.body.shapes.length=0; p.body.shapeOffsets.length=0; p.body.shapeOrientations.length=0;
  shapes.forEach(x=>p.body.addShape(x.s,x.o,x.q));
  p.body.updateMassProperties();
  if(p.body.updateBoundingRadius) p.body.updateBoundingRadius();
  p.body.aabbNeedsUpdate=true;
}
function setRot(p){
  const q=new CANNON.Quaternion();
  q.setFromEuler(p.rot.x*Math.PI/180,p.rot.y*Math.PI/180,p.rot.z*Math.PI/180,'XYZ');
  girarGrupo(p,q);                 // gira a montagem inteira, não só a peça
  p.hq=p.body.quaternion.clone();
  links.forEach(function(l){ if(grupoDe(p).indexOf(l.pa)>=0) refazer(l); });
  sync();
}
function addPart(tipo,pos){
  const par={}; for(const k in CAT[tipo].p) par[k]=CAT[tipo].p[k].v;
  const r=build(tipo,par);
  const body=new CANNON.Body({mass:1});
  r.shapes.forEach(x=>body.addShape(x.s,x.o,x.q));
  body.position.copy(pos||new CANNON.Vec3((Math.random()-0.5)*0.2,0.5,(Math.random()-0.5)*0.2));
  body.collisionFilterGroup=2; body.collisionFilterMask=-1;
  world.addBody(body); scene.add(r.mesh);
  const p={id:++nId,tipo,par,rot:{x:0,y:0,z:0},asm:null,body,mesh:r.mesh,
           home:body.position.clone(),hq:body.quaternion.clone()};
  parts.push(p); sel=[p]; paint(); ui(); sync(); return p;
}
function rebuild(p){
  const r=build(p.tipo,p.par);
  scene.remove(p.mesh); p.mesh=r.mesh; scene.add(r.mesh);
  aplicar(p,r.shapes); paint(); sync();
}
// A LockConstraint do cannon 0.6.2 tem um BUG: o update() usa Vec3.UNIT_X/Y/Z
// fixos em vez dos eixos do momento da solda, então ela ALINHA as peças em vez
// de travá-las como estão. Correção (igual à do cannon-es): guardar os eixos.
function soldar(a,b){
  const V=CANNON.Vec3;
  const c=new CANNON.LockConstraint(a,b);
  const xA=a.vectorToLocalFrame(new V(1,0,0)), yA=a.vectorToLocalFrame(new V(0,1,0)), zA=a.vectorToLocalFrame(new V(0,0,1));
  const xB=b.vectorToLocalFrame(new V(1,0,0)), yB=b.vectorToLocalFrame(new V(0,1,0)), zB=b.vectorToLocalFrame(new V(0,0,1));
  c.update=function(){
    CANNON.PointToPointConstraint.prototype.update.call(this);
    a.vectorToWorldFrame(xA,this.rotationalEquation1.axisA);
    b.vectorToWorldFrame(yB,this.rotationalEquation1.axisB);
    a.vectorToWorldFrame(yA,this.rotationalEquation2.axisA);
    b.vectorToWorldFrame(zB,this.rotationalEquation2.axisB);
    a.vectorToWorldFrame(zA,this.rotationalEquation3.axisA);
    b.vectorToWorldFrame(xB,this.rotationalEquation3.axisB);
  };
  return c;
}
// O Cannon não tem junta prismática. Construída com o que ele tem:
// trava as 2 direções perpendiculares, libera a 3ª, e trava a rotação.
function fazTrilho(a,b,pa,pb,dirW){
  const V=CANNON.Vec3;
  const c=new CANNON.PointToPointConstraint(a,pa,b,pb,1e6);
  const dA=a.quaternion.inverse().vmult(new V(dirW.x,dirW.y,dirW.z)); dA.normalize();
  c.equationZ.maxForce=0; c.equationZ.minForce=0;          // eixo LIVRE
  const r1=new CANNON.RotationalEquation(a,b), r2=new CANNON.RotationalEquation(a,b),
        r3=new CANNON.RotationalEquation(a,b);
  c.equations.push(r1,r2,r3);
  const xA=a.vectorToLocalFrame(new V(1,0,0)), yA=a.vectorToLocalFrame(new V(0,1,0)),
        zA=a.vectorToLocalFrame(new V(0,0,1));
  const xB=b.vectorToLocalFrame(new V(1,0,0)), yB=b.vectorToLocalFrame(new V(0,1,0)),
        zB=b.vectorToLocalFrame(new V(0,0,1));
  const t1=new V(), t2=new V();
  c.update=function(){
    CANNON.PointToPointConstraint.prototype.update.call(this);
    const d=a.quaternion.vmult(dA); d.normalize(); d.tangents(t1,t2);
    this.equationX.ni.copy(t1); this.equationY.ni.copy(t2); this.equationZ.ni.copy(d);
    a.vectorToWorldFrame(xA,r1.axisA); b.vectorToWorldFrame(yB,r1.axisB);
    a.vectorToWorldFrame(yA,r2.axisA); b.vectorToWorldFrame(zB,r2.axisB);
    a.vectorToWorldFrame(zA,r3.axisA); b.vectorToWorldFrame(xB,r3.axisB);
  };
  c._dirLocalA=dA;
  return c;
}
// fim de curso: sem isto o carro sai voando pela ponta da haste
function limitarTrilhos(){
  links.forEach(function(l){
    if(l.kind!=='trilho'||!l.c._dirLocalA) return;
    const A=l.pa.body, B=l.pb.body;
    const d=A.quaternion.vmult(l.c._dirLocalA);
    const piv=A.pointToWorldFrame(l.pivA);
    const r=new CANNON.Vec3(B.position.x-piv.x,B.position.y-piv.y,B.position.z-piv.z);
    const s=r.dot(d), lim=l.curso/2;
    if(Math.abs(s)>lim){
      const corr=(Math.abs(s)-lim)*(s>0?1:-1);
      B.position.x-=d.x*corr; B.position.y-=d.y*corr; B.position.z-=d.z*corr;
      const vd=B.velocity.dot(d);
      if(vd*(s>0?1:-1)>0){ B.velocity.x-=d.x*vd; B.velocity.y-=d.y*vd; B.velocity.z-=d.z*vd; }
    }
  });
}
// comprimento útil do trilho, vindo da peça que serve de haste
function cursoDa(p){
  if(p.tipo==='barra') return p.par.comp;
  if(p.tipo==='placa') return Math.max(p.par.larg,p.par.prof);
  if(p.tipo==='arco') return p.par.raio*2;
  return 0.3;
}
function montarLigacao(a,b,kind,pivW,axDir){
  const mid=new CANNON.Vec3(pivW.x,pivW.y,pivW.z);
  const pa=a.body.pointToLocalFrame(mid), pb=b.body.pointToLocalFrame(mid);
  let c, axL=null;
  if(kind==='weld') c=soldar(a.body,b.body);
  else if(kind==='ball') c=new CANNON.PointToPointConstraint(a.body,pa,b.body,pb,1e6);
  else if(kind==='trilho'){
    c=fazTrilho(a.body,b.body,pa,pb,axDir);
    axL=c._dirLocalA;
  }
  else if(kind==='pino'){
    // o pino atravessa B pelo EIXO DELA (local X) — é isto que faz roda ser roda
    const axB=new CANNON.Vec3(1,0,0);
    const axW=b.body.quaternion.vmult(axB);
    axL=a.body.quaternion.inverse().vmult(axW);
    c=new CANNON.HingeConstraint(a.body,b.body,{pivotA:pa,pivotB:pb,axisA:axL,axisB:axB});
  }
  else{
    const d=axDir.clone().normalize();
    const ax=new CANNON.Vec3(d.x,d.y,d.z);       // eixo ARBITRÁRIO no mundo
    axL=a.body.quaternion.inverse().vmult(ax);
    c=new CANNON.HingeConstraint(a.body,b.body,{pivotA:pa,pivotB:pb,
      axisA:axL, axisB:b.body.quaternion.inverse().vmult(ax)});
  }
  return {c:c,pa:pa,pb:pb,axL:axL};
}
// REFAZ a ligação com o pivô/eixo/tipo novos — é o que torna a junta editável
function aplicarMotor(l){
  if(!l.motor || (l.kind!=='hinge'&&l.kind!=='pino'&&l.kind!=='trilho') || !l.c.enableMotor) return;
  if(l.motor.on){
    l.c.enableMotor();
    // MOMENTÂNEO: só gira enquanto houver comando; senão trava em 0
    l.c.setMotorSpeed(l.motor.ativo ? l.motor.vel : 0);
    l.c.setMotorMaxForce(l.motor.forca);
  } else if(l.c.disableMotor) l.c.disableMotor();
}
function comandar(l,dir){   // dir: -1, 0, +1
  l.motor.ativo = dir!==0;
  l.motor.vel = dir * Math.abs(l.motor.mag);
  aplicarMotor(l);
}
function refazer(l){
  world.removeConstraint(l.c);
  if(l.mk) scene.remove(l.mk);
  if(l.mkB) scene.remove(l.mkB);
  const r=montarLigacao(l.pa,l.pb,l.kind,l.pivW,dirDeAng(l.axAz,l.axEl));
  world.addConstraint(r.c);
  l.c=r.c; l.pivA=r.pa; l.pivB=r.pb; l.axL=r.axL;
  aplicarMotor(l);
  l.mk=mkMarcador(l.kind,false); scene.add(l.mk);
  l.mkB=new THREE.Mesh(new THREE.SphereGeometry(0.009,12,8),
    new THREE.MeshBasicMaterial({color:0xd9a04a}));
