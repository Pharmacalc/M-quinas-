              pivA:pa,pivB:pb,axL:r.axL,pivW:P.clone(),curso:cursoDa(a),
              axAz:angDeDir(dir).az, axEl:angDeDir(dir).el,
              motor:{on:false,vel:0,mag:3,forca:30,ativo:false}});
