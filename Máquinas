// ── ESPELHO: 1ª peça = âncora (define o plano), 2ª = o que espelhar ──
function matEspelho(n){
  return new THREE.Matrix4().set(
    1-2*n.x*n.x, -2*n.x*n.y, -2*n.x*n.z, 0,
    -2*n.y*n.x, 1-2*n.y*n.y, -2*n.y*n.z, 0,
    -2*n.z*n.x, -2*n.z*n.y, 1-2*n.z*n.z, 0, 0,0,0,1);
}
function refletePonto(v,pl,n){ // reflete v no plano que passa por pl com normal n
  const d=v.clone().sub(pl);
  return pl.clone().add(d.sub(n.clone().multiplyScalar(2*d.dot(n))));
}
function refleteQuat(q,n){    // R' = M R M -> continua rotação (det=+1)
  const M=matEspelho(n);
  const R=new THREE.Matrix4().makeRotationFromQuaternion(
    new THREE.Quaternion(q.x,q.y,q.z,q.w));
  const R2=new THREE.Matrix4().multiplyMatrices(M,R).multiply(M);
  return new THREE.Quaternion().setFromRotationMatrix(R2);
}
// tudo que pende da peça, SEM atravessar a âncora
function ramoDe(p,ancora){
  const vis=[p], fila=[p];
  while(fila.length){
    const cur=fila.pop();
    links.forEach(function(l){
      const o=(l.pa===cur)?l.pb:(l.pb===cur)?l.pa:null;
      if(o && o!==ancora && vis.indexOf(o)<0){ vis.push(o); fila.push(o); }
    });
  }
  return vis;
}
function duplicarBloco(p){
  const grupo=grupoDe(p);                 // a montagem conexa inteira
  const off=new THREE.Vector3(0.18,0,0.18);
  const mapa=new Map();
  grupo.forEach(function(o){
    const q=addPart(o.tipo,new CANNON.Vec3(0,0,0));
    Object.keys(o.par).forEach(k=>q.par[k]=o.par[k]);
    rebuild(q);
    q.body.position.set(o.body.position.x+off.x, o.body.position.y, o.body.position.z+off.z);
    q.body.quaternion.copy(o.body.quaternion);
    q.rot.x=o.rot.x; q.rot.y=o.rot.y; q.rot.z=o.rot.z;
    q.home=q.body.position.clone(); q.hq=q.body.quaternion.clone();
    mapa.set(o,q);
  });
  links.slice().forEach(function(l){
    const A=mapa.get(l.pa), B=mapa.get(l.pb);
    if(!A||!B) return;                     // só ligações internas ao bloco
    const pv=l.pivW.clone().add(off);
    const dir=dirDeAng(l.axAz,l.axEl);
    const r=montarLigacao(A,B,l.kind,pv,dir);
    world.addConstraint(r.c);
    unir(A,B);
    const mk=mkMarcador(l.kind,false); scene.add(mk);
