      new THREE.MeshBasicMaterial({color:0xd9a04a}));
    scene.add(mkB);
    const nl={c:r.c,kind:l.kind,a:A.id,b:B.id,pa:A,pb:B,mk:mk,mkB:mkB,
      pivA:r.pa,pivB:r.pb,axL:r.axL,pivW:pv.clone(),curso:l.curso,
      axAz:l.axAz,axEl:l.axEl,
      motor:{on:l.motor.on,vel:0,mag:l.motor.mag,forca:l.motor.forca,ativo:false,inv:l.motor.inv}};
    links.push(nl); aplicarMotor(nl);
  });
  const novo=mapa.get(p);
  sel=novo?[novo]:[]; selLink=null; paint(); ui(); sync();
}
function espelhar(eixo){
  if(sel.length!==2) return;
  const anc=sel[0], alvoP=sel[1];
  const n=eixoMundo(eixo);
  const pl=new THREE.Vector3(anc.body.position.x,anc.body.position.y,anc.body.position.z);
  const ramo=ramoDe(alvoP,anc);
  const mapa=new Map();
  ramo.forEach(function(o){
    const q=addPart(o.tipo,new CANNON.Vec3(0,0,0));
    Object.keys(o.par).forEach(k=>q.par[k]=o.par[k]);
    rebuild(q);
    const pw=refletePonto(new THREE.Vector3(o.body.position.x,o.body.position.y,o.body.position.z),pl,n);
    q.body.position.set(pw.x,pw.y,pw.z);
    const qq=refleteQuat(o.body.quaternion,n);
    q.body.quaternion.set(qq.x,qq.y,qq.z,qq.w);
    const e=new CANNON.Vec3(); q.body.quaternion.toEuler(e);
    q.rot.x=e.x*180/Math.PI; q.rot.y=e.y*180/Math.PI; q.rot.z=e.z*180/Math.PI;
    q.home=q.body.position.clone(); q.hq=q.body.quaternion.clone();
    mapa.set(o,q);
  });
  // recria as ligações: dentro do ramo E do ramo para a âncora
  const feitas=[];
  links.slice().forEach(function(l){
    const A=mapa.get(l.pa)|| (l.pa===anc?anc:null);
    const B=mapa.get(l.pb)|| (l.pb===anc?anc:null);
    if(!A||!B) return;
    if(A===anc&&B===anc) return;
    if(!mapa.get(l.pa)&&!mapa.get(l.pb)) return;   // nenhuma ponta é cópia
    const pv=refletePonto(l.pivW,pl,n);
    const dirO=dirDeAng(l.axAz,l.axEl);
    const dirE=dirO.clone().sub(n.clone().multiplyScalar(2*dirO.dot(n)));
    const r=montarLigacao(A,B,l.kind,pv,dirE);
    world.addConstraint(r.c);
    unir(A,B);
    const mk=mkMarcador(l.kind,false); scene.add(mk);
    const mkB=new THREE.Mesh(new THREE.SphereGeometry(0.009,12,8),
      new THREE.MeshBasicMaterial({color:0xd9a04a}));
    scene.add(mkB);
    feitas.push({c:r.c,kind:l.kind,a:A.id,b:B.id,pa:A,pb:B,mk:mk,mkB:mkB,
      pivA:r.pa,pivB:r.pb,axL:r.axL,pivW:pv.clone(),curso:l.curso,
      axAz:angDeDir(dirE).az, axEl:angDeDir(dirE).el,
      motor:{on:l.motor.on, vel:0, mag:l.motor.mag, forca:l.motor.forca, ativo:false, inv:!l.motor.inv}});
  });
  feitas.forEach(function(l){ links.push(l); aplicarMotor(l); });
  sel=[]; paint(); ui(); sync();
}
function join(kind){
  if(sel.length!==2) return;
  const a=sel[0], b=sel[1];
  // pino: automático no centro da 2ª peça, no eixo dela. Sem posicionar nada.
  const P = (kind==='pino')
    ? new THREE.Vector3(b.body.position.x,b.body.position.y,b.body.position.z)
    : pivotAtual();
  const mid=new CANNON.Vec3(P.x,P.y,P.z);
  const dir = (kind==='pino') ? eixoDaPeca(b)
            : (kind==='trilho') ? eixoDaPeca(a)      // a haste É o trilho
            : dirDeAng(novoAz,novoEl);
  const r=montarLigacao(a,b,kind,P,dir);
  const c=r.c, pa=r.pa, pb=r.pb;
  world.addConstraint(c);
  unir(a,b);
  const mk=mkMarcador(kind,false); scene.add(mk);
  // âncora do lado B: se as duas se separarem, você VÊ a junta abrindo
