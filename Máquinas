function pts(e){ return e.touches?Array.prototype.map.call(e.touches,t=>({x:t.clientX,y:t.clientY})):[{x:e.clientX,y:e.clientY}]; }
function down(e){ const P=pts(e); moved=0;
  if(P.length===2){ pinch=Math.hypot(P[0].x-P[1].x,P[0].y-P[1].y);
    cen={x:(P[0].x+P[1].x)/2,y:(P[0].y+P[1].y)/2}; drag=null; last=null; return; }
  panning = !!(e.shiftKey || e.button===2 || e.button===1);
  last=P[0];
  dragPiv = (!running && !panning && sel.length===2 && pegouPivo(P[0].x,P[0].y));
  dragLink = (!running && !panning && selLink && pickLink(P[0].x,P[0].y)===selLink);
  if(modoPivo && (sel.length===2||selLink) && !dragPiv && !dragLink){ drag=null; return; }
  drag=(running||panning||dragPiv)?null:pick(P[0].x,P[0].y); }
function move(e){ const P=pts(e);
  if(P.length===2&&pinch){ if(e.cancelable)e.preventDefault();
    const dd=Math.hypot(P[0].x-P[1].x,P[0].y-P[1].y);
    const nc={x:(P[0].x+P[1].x)/2,y:(P[0].y+P[1].y)/2};
    if(dd>0){ orb.d=Math.max(0.3,Math.min(14,orb.d*pinch/dd)); pinch=dd; }
    if(cen) pan(nc.x-cen.x, nc.y-cen.y);
    cen=nc; placeCam(); return; }
  if(!last) return; if(e.cancelable) e.preventDefault();
  const dx=P[0].x-last.x, dy=P[0].y-last.y; moved+=Math.abs(dx)+Math.abs(dy);
  if(dragLink&&selLink){
    const s=orb.d*0.0024;
    const fwd=new THREE.Vector3(); cam.getWorldDirection(fwd);
    const rv=new THREE.Vector3().crossVectors(fwd,new THREE.Vector3(0,1,0)).normalize();
    const upv=new THREE.Vector3().crossVectors(rv,fwd).normalize();
    if(!selLink._livre) selLink._livre=selLink.pivW.clone();
    selLink._livre.addScaledVector(rv,dx*s); selLink._livre.addScaledVector(upv,-dy*s);
    selLink.pivW.copy(comIma(selLink._livre.clone(),[selLink.pa,selLink.pb]));
    refazer(selLink);
  } else if(dragPiv){
    const s=orb.d*0.0024;
    const fwd=new THREE.Vector3(); cam.getWorldDirection(fwd);
    const rv=new THREE.Vector3().crossVectors(fwd,new THREE.Vector3(0,1,0)).normalize();
    const upv=new THREE.Vector3().crossVectors(rv,fwd).normalize();
    if(!pivotLivre) pivotLivre=pivotAtual();
    pivotLivre.addScaledVector(rv,dx*s); pivotLivre.addScaledVector(upv,-dy*s);
    pivotUser=comIma(pivotLivre.clone(),sel);   // o ímã NÃO realimenta o arrasto
    verPrevia();
  } else if(drag){
    const s=orb.d*0.0024;
    const fwd=new THREE.Vector3(); cam.getWorldDirection(fwd);
    const rv=new THREE.Vector3().crossVectors(fwd,new THREE.Vector3(0,1,0)).normalize();
    const g=grupoDe(drag);
    const ax=rv.x*dx*s, az=rv.z*dx*s;
    let ay=-dy*s;
    const menor=Math.min.apply(null,g.map(o=>o.body.position.y));
    if(menor+ay<0.02) ay=0.02-menor;      // o bloco todo respeita o chão
    moverGrupo(g,ax,ay,az); sync();
  } else if(panning){ pan(dx,dy);
  } else { orb.az-=dx*0.008; orb.el=Math.max(-0.2,Math.min(1.4,orb.el+dy*0.006)); placeCam(); }
  last=P[0]; }
function up(){ if(dragLink){ dragLink=false; last=null; moved=0;
    if(selLink) selLink._livre=null; return; }
  if(dragPiv){ dragPiv=false; last=null; moved=0; pivotLivre=null; return; }
  if(modoPivo && moved<8 && last && selLink){
    const s=pontoNaSuperficieDe([selLink.pa,selLink.pb],last.x,last.y);
    if(s){ selLink._livre=s.clone();
      selLink.pivW.copy(comIma(s.clone(),[selLink.pa,selLink.pb])); refazer(selLink); last=null; return; }
  }
  if(modoPivo && moved<8 && last && sel.length===2){
    const s=pontoNaSuperficie(last.x,last.y);
    if(s){ pivotLivre=s.clone(); pivotUser=comIma(s.clone(),sel); verPrevia(); last=null; return; }
  }
  if(moved<8&&last){
    const lk=pickLink(last.x,last.y);
    if(lk){ selLink=(selLink===lk)?null:lk; sel=[]; paint(); ui(); last=null; drag=null; return; }
    const p=drag||pick(last.x,last.y);
    if(p){ selLink=null; toggle(p); } else { sel=[]; selLink=null; paint(); ui(); } }
  if(dragPiv){ dragPiv=false; last=null; return; }
  last=null; drag=null; pinch=null; cen=null; panning=false; }
